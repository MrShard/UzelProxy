{
    "background": {
        "service_worker": "sw.js"
    },
    "action": {
        "default_icon": {
            "16": "icon-16-on.png",
            "32": "icon-32-on.png",
            "48": "icon-48-on.png",
            "128": "icon-128-on.png"
        },
        "default_popup": "popup/popup.html"
    },
    "icons": {
        "16": "icon-16-on.png",
        "32": "icon-32-on.png",
        "48": "icon-48-on.png",
        "128": "icon-128-on.png"
    },
    "manifest_version": 3,
	"minimum_chrome_version": "104.0.0.0",
    "name": "UzelProxy — менеджер личных прокси",
    "short_name": "UzelProxy",
    "description": "Гибкое управление собственными прокси: какие сайты идут через ваш прокси, какие — напрямую. Менеджер нескольких прокси, списки исключений, проверка соединения.",
    "homepage_url": "https://github.com/MrShard/UzelProxy",
    "permissions": ["proxy", "tabs", "storage", "unlimitedStorage", "alarms", "scripting"],
	"host_permissions": ["<all_urls>"],
	"optional_permissions": ["management"],
    "version": "8.0.0"
}